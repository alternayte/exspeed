{
  "name": "@exspeed/sdk",
  "version": "0.1.0",
  "description": "TypeScript client SDK for Exspeed — a stream processing platform with an integrated SQL-like query engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "exspeed",
    "streaming",
    "sdk",
    "client",
    "message-broker",
    "stream-processing"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alternayte/exspeed.git",
    "directory": "sdks/typescript"
  },
  "homepage": "https://github.com/alternayte/exspeed/tree/main/sdks/typescript#readme",
  "bugs": {
    "url": "https://github.com/alternayte/exspeed/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "@types/node": "^20.0.0"
  }
}
